{
  "name": "lawcopilot-desktop",
  "private": true,
  "version": "0.7.0-pilot.3",
  "description": "Pilot desktop shell for LawCopilot",
  "author": "LawCopilot Team",
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "prepare:package": "node scripts/close-running-desktop.cjs",
    "sync:ui": "node scripts/sync-ui-dist.cjs",
    "update:runtime": "bash ../../scripts/update_desktop_runtime.sh",
    "build:browser-worker": "node scripts/build-browser-worker.cjs",
    "test:runtime": "node scripts/desktop-smoke.cjs",
    "test:whatsapp-runtime": "node scripts/whatsapp-runtime-smoke.cjs",
    "test:workspace": "node scripts/workspace-security-smoke.cjs",
    "test:integrations": "node scripts/integration-config-smoke.cjs",
    "test:codex-auth": "node scripts/codex-auth-smoke.cjs",
    "test:packaged": "node scripts/packaged-runtime-smoke.cjs",
    "test:lifecycle": "node scripts/packaged-lifecycle-smoke.cjs",
    "test:updater": "node scripts/updater-smoke.cjs",
    "test": "npm run build:browser-worker && npm run test:runtime && npm run test:whatsapp-runtime && npm run test:workspace && npm run test:integrations && npm run test:codex-auth && npm run test:packaged && npm run test:updater",
    "build:backend": "node scripts/build-backend.cjs",
    "build:backend:windows": "node scripts/build-backend.cjs windows",
    "build:backend:macos": "node scripts/build-backend.cjs macos",
    "package:dir": "npm run prepare:package && npm run build:browser-worker && npm --prefix ../browser-worker run install:chromium:bundled && npm run build:backend && electron-builder --dir --publish never",
    "package:linux": "npm run prepare:package && npm run build:browser-worker && npm --prefix ../browser-worker run install:chromium:bundled && npm run build:backend && electron-builder --linux AppImage dir --publish never",
    "package:windows": "npm run prepare:package && npm run build:browser-worker && npm --prefix ../browser-worker run install:chromium:bundled && npm run build:backend:windows && electron-builder --win nsis --x64 --publish never",
    "package:macos": "npm run prepare:package && npm run build:browser-worker && npm --prefix ../browser-worker run install:chromium:bundled && npm run build:backend:macos && electron-builder --mac dmg zip --universal --publish never",
    "package": "npm run package:dir"
  },
  "devDependencies": {
    "electron": "^36.3.2",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.lawcopilot.desktop",
    "productName": "LawCopilot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "package.json",
      "main.cjs",
      "preload.cjs",
      "lib/**/*",
      "scripts/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../ui/dist",
        "to": "ui-dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../api/dist",
        "to": "api-bin",
        "filter": [
          "lawcopilot-api*"
        ]
      },
      {
        "from": "../browser-worker/dist",
        "to": "browser-worker/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../browser-worker/node_modules/playwright",
        "to": "browser-worker/node_modules/playwright",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../browser-worker/node_modules/playwright-core",
        "to": "browser-worker/node_modules/playwright-core",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../browser-worker/.bundled-browsers",
        "to": "browser-worker/.bundled-browsers",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        "dir"
      ],
      "category": "Office"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "artifactName": "LawCopilot-${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "Yosemiteee",
        "repo": "LawCopilot",
        "vPrefixedTagName": true
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "LawCopilot"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "electron-updater": "^6.6.2",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.6"
  }
}
